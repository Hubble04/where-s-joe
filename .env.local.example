# ─────────────────────────────────────────────────────────────
# Where's Joe? — environment variables
# Copy this file to `.env.local` and fill in what you have.
# EVERYTHING IS OPTIONAL. With no keys at all, the app runs on
# bundled mock data + a static fallback map (great for demos).
# ─────────────────────────────────────────────────────────────

# Supabase (auth + database + image storage).
# Get these from your Supabase project: Settings → API.
# Missing → app uses local mock café data and guest-mode passport
# (check-ins stored in the browser's localStorage).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox (interactive map).
# Get a token at https://account.mapbox.com/access-tokens/
# Missing → app shows a styled static map with positioned pins.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: where the app lives in production (used for PWA/share links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000